{
  //"extends": "../../tsconfig.json",
  "compilerOptions": {
    //"composite": true,
    //"baseUrl": ".",
    /* "paths": {
      "@flashcards/backend": ["../backend/src/index.ts"],
      "@flashcards/types": ["../types/src/index.ts"]
    }, */
    "target": "ESNext",
    "useDefineForClassFields": true,
    "lib": ["DOM", "DOM.Iterable", "ESNext"],
    "allowJs": false,
    "skipLibCheck": true,
    "esModuleInterop": false,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "module": "ESNext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": false, // was true by redux template
    "outDir": "./dist",
    "jsx": "react-jsx",
    "types": ["vitest/globals"]
  },

  "references": [{ "path": "./tsconfig.node.json" }, { "path": "../types" }]
}
