{
  //"extends": "../../tsconfig.json",
  "compilerOptions": {
    //"composite": true,
    "paths": {
      "@app": ["./src/app/"],
      "@pages/*": ["./src/pages/*"],
      "@widgets/*": ["./src/widgets/*"],
      "@features/*": ["./src/features/*"],
      "@entities/*": ["./src/entities/*"],
      "@shared/*": ["./src/shared/*"],
      "@assets/*": ["./src/assets/*"],
      "vite-env": ["./src/vite-env.d.ts"]
    },
    "target": "ESNext",
    "useDefineForClassFields": true,
    "lib": ["DOM", "DOM.Iterable", "ESNext"],
    "allowJs": false,
    "skipLibCheck": true, // was true by redux template
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "module": "ESNext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true, // was true by redux template
    "outDir": "./dist",
    "jsx": "react-jsx",
    "types": ["vitest/globals"],
    "plugins": [{ "name": "typescript-plugin-css-modules" }]
  },
  "include": ["src"],
  "references": [{ "path": "./tsconfig.node.json" }],
  "exclude": [
    "node_modules",
    "dist",
    "vite.config.ts",
    "vite.config.js",
    "jest.config.ts",
    "jest.config.js"
  ]
}
