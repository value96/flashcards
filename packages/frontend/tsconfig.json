{
  //"extends": "../../tsconfig.json",
  "compilerOptions": {
    //"composite": true,
    "baseUrl": "src",
    "paths": {
      "@app": ["app/"],
      "@pages/*": ["pages/*"],
      "@widgets/*": ["widgets/*"],
      "@features/*": ["features/*"],
      "@entities/*": ["entities/*"],
      "@shared/*": ["shared/*"],
      "@flashcards/flashcard-types": ["../flashcard-types/dist/index.d.ts"]
    },
    "target": "ESNext",
    "useDefineForClassFields": true,
    "lib": ["DOM", "DOM.Iterable", "ESNext"],
    "allowJs": false,
    "skipLibCheck": false, // was true by redux template
    "esModuleInterop": false,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "module": "ESNext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true, // was true by redux template
    "outDir": "./dist",
    "jsx": "react-jsx",
    "types": ["vitest/globals"],
    "plugins": [{ "name": "typescript-plugin-css-modules" }]
  },
  "include": ["src"],
  "references": [
    { "path": "./tsconfig.node.json" },
    { "path": "../flashcard-types" }
  ],
  "exclude": [
    "node_modules",
    "dist",
    "vite.config.ts",
    "vite.config.js",
    "jest.config.ts",
    "jest.config.js"
  ]
}
