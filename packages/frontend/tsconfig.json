{
  //"extends": "../../tsconfig.json",
  "compilerOptions": {
    //"composite": true,
    "baseUrl": "src",
    "paths": {
      "@shared/*": ["shared/*"],
      "@flashcards/types": ["../types/dist/index.d.ts"]
    },
    "target": "ESNext",
    "useDefineForClassFields": true,
    "lib": ["DOM", "DOM.Iterable", "ESNext"],
    "allowJs": false,
    "skipLibCheck": false, // was true by redux template
    "esModuleInterop": false,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "module": "ESNext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true, // was true by redux template
    "outDir": "./dist",
    "jsx": "react-jsx",
    "types": ["vitest/globals"]
  },

  "references": [{ "path": "./tsconfig.node.json" }, { "path": "../types" }],
  "exclude": [
    "node_modules",
    "dist",
    "vite.config.ts",
    "vite.config.js",
    "jest.config.ts",
    "jest.config.js"
  ]
}
