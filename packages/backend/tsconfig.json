{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "rootDir": "./src",
    "outDir": "./dist",
    "baseUrl": ".",
    "paths": {
      "@flashcards/types": ["../types/src/index.ts"]
    },
    "sourceMap": true,
    "resolveJsonModule": true,
    "composite": true,
    "allowJs": false,
    "declaration": true,
    "declarationMap": true,
    "allowSyntheticDefaultImports": true
  },
  "references": [{ "path": "../types" }],
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}

